# Copy to .env for local development (never commit .env).
# Netlify: set the same keys in Site configuration → Environment variables.

# App
VITE_APP_NAME=Visa Eligibility AI
VITE_APP_TAGLINE=Intelligent visa pathway assessment
VITE_SUPPORT_EMAIL=support@example.com
VITE_API_BASE_URL=https://api.example.com

# Demo login (replace when Firebase auth is enabled)
VITE_AUTH_USERNAME=admin
VITE_AUTH_PASSWORD=visaadm

# Firebase (optional until Google sign-in is enabled)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# LLM — hybrid = Groq for long tasks, Gemini for critical/small tasks
VITE_LLM_PROVIDER=hybrid
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_MODEL_FALLBACKS=
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY
VITE_GROQ_MODEL=llama-3.1-8b-instant
VITE_MAX_PROFILE_CHARS=8000
# Groq on_demand llama-3.1-8b-instant: ~6000 tokens/request (input + completion)
VITE_GROQ_MAX_PROFILE_CHARS=2800
VITE_GROQ_MAX_SYSTEM_CHARS=2400
VITE_GROQ_MAX_USER_CHARS=2800
VITE_GROQ_MAX_INPUT_TOKENS=3800
VITE_GROQ_MAX_INPUT_TOKENS_AGGRESSIVE=3200
VITE_GROQ_MAX_COMPLETION_TOKENS=1200
VITE_GROQ_MAX_COMPLETION_TOKENS_LARGE_JSON=2048
VITE_GROQ_MAX_COMPLETION_TOKENS_ROADMAP=1600
VITE_GROQ_MAX_COMPLETION_TOKENS_AGGRESSIVE=1536
VITE_LLM_TEMPERATURE=0.2
VITE_LLM_TOP_P=0.9
VITE_REQUIRE_LLM_OUTPUT=true

# Feature flags
VITE_ENABLE_GOOGLE_SIGN_IN=false
VITE_ENABLE_REGISTRATION=true
